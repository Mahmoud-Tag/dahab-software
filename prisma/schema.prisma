generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "auth"]
}

model User {
  id                   Int                   @id @default(autoincrement())
  name                 String
  email                String                @unique
  emailVerifiedAt      DateTime?             @map("email_verified_at")
  password             String
  rememberToken        String?               @map("remember_token")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  personalAccessTokens PersonalAccessToken[]

  @@map("users")
  @@schema("public")
}

model PersonalAccessToken {
  id            Int       @id @default(autoincrement())
  tokenableType String    @map("tokenable_type")
  tokenableId   Int       @map("tokenable_id")
  name          String
  token         String    @unique
  abilities     String?
  lastUsedAt    DateTime? @map("last_used_at")
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [tokenableId], references: [id], onDelete: Cascade)

  @@index([tokenableType, tokenableId])
  @@map("personal_access_tokens")
  @@schema("public")
}

model Project {
  id            Int      @id @default(autoincrement())
  title         String
  category      String
  catIcon       String?
  desc          String?  @db.Text
  fullDesc      String?  @db.Text
  image         String?
  imagePublicId String?  @map("image_public_id")
  tags          Json?
  year          String?
  type          String?
  language      String?
  downloads     Int      @default(0)
  downloadUrl   String?
  websiteUrl    String?
  status        String?
  features      Json?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@map("projects")
  @@schema("public")
}

model Message {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@map("messages")
  @@schema("public")
}

model TeamMember {
  id            Int      @id @default(autoincrement())
  name          String
  role          String
  image         String?
  imagePublicId String?  @map("image_public_id")
  specialty     String?
  email         String?
  phone         String?
  linkedin      String?
  github        String?
  twitter       String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("team_members")
  @@schema("public")
}

model Partnership {
  id            Int      @id @default(autoincrement())
  title         String
  partnerName   String
  desc          String?  @db.Text
  fullDesc      String?  @db.Text
  image         String?
  imagePublicId String?  @map("image_public_id")
  websiteUrl    String?
  status        String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@map("partnerships")
  @@schema("public")
}
