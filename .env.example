# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Supabase Postgres connection string)
# IMPORTANT: If your password contains special characters (@ # $ % etc),
# they must be URL-encoded:
#   @ → %40    # → %23    $ → %24    % → %25
# Example: password@123 → password%40123
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_HOST.supabase.co:5432/postgres"

# Supabase (optional — used for auth only, storage is now local)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_HOST.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin seed (optional overrides)
ADMIN_EMAIL=admin@dahab.tech
ADMIN_PASSWORD=admin123